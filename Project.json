{
  "configs": {
    "Debug": "debug",
    "Release": "release"
  },
  "name": "Lakshya",
  "options": {
    "groupSortPosition": "bottom",
    "transitivelyLinkDependencies": false
  },
  "settings": {
    "CODE_SIGN_IDENTITY": "-"
  },
  "targets": {
    "Lakshya": {
      "deploymentTarget": "26.0",
      "info": {
        "path": "App\/Info.plist",
        "properties": {
          "CFBundleDisplayName": "Lakshya",
          "CFBundleShortVersionString": "1.0",
          "CFBundleVersion": "1",
          "ITSAppUsesNonExemptEncryption": false,
          "UILaunchScreen": {},
          "UISupportedInterfaceOrientations": [
            "UIInterfaceOrientationPortrait",
            "UIInterfaceOrientationPortraitUpsideDown",
            "UIInterfaceOrientationLandscapeLeft",
            "UIInterfaceOrientationLandscapeRight"
          ]
        }
      },
      "platform": "iOS",
      "settings": {
        "ASSETCATALOG_COMPILER_APPICON_NAME": "AppIcon",
        "ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME": "AccentColor",
        "CURRENT_PROJECT_VERSION": "1",
        "MARKETING_VERSION": "1.0",
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.new.b145bb62-2e41-4b13-b0f9-1aef109f9aa8",
        "PRODUCT_NAME": "$(TARGET_NAME)",
        "SWIFT_VERSION": "5.0",
        "TARGETED_DEVICE_FAMILY": "1"
      },
      "sources": [
        {
          "path": "App"
        }
      ],
      "type": "application"
    },
    "LakshyaTests": {
      "platform": "iOS",
      "settings": {
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.new.b145bb62-2e41-4b13-b0f9-1aef109f9aa8.tests",
        "SWIFT_VERSION": "5.0"
      },
      "sources": [
        {
          "path": "UnitTests"
        }
      ],
      "dependencies": [
        {
          "target": "Lakshya"
        }
      ],
      "type": "bundle.unit-test"
    },
    "LakshyaUITests": {
      "platform": "iOS",
      "settings": {
        "PRODUCT_BUNDLE_IDENTIFIER": "app.bitrig.new.b145bb62-2e41-4b13-b0f9-1aef109f9aa8.uitests",
        "SWIFT_VERSION": "5.0",
        "TEST_TARGET_NAME": "Lakshya"
      },
      "sources": [
        {
          "path": "UITests"
        }
      ],
      "dependencies": [
        {
          "target": "Lakshya"
        }
      ],
      "type": "bundle.ui-testing"
    }
  }
}
